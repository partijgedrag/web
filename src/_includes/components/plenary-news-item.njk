{% macro plenaryNewsItem(params) %}
{% set meeting = params.meeting %}
{% set attendance = meeting.attendance %}
{% set attendanceColor = "#ff4c40" %}
{% if attendance.ratio >= 0.85 %}
{% set attendanceColor = "#28a745" %}
{% elif attendance.ratio >= 0.65 %}
{% set attendanceColor = "#ff4c40" %}
{% endif %}

<div class="swipeable-item card" style="height: fit-content;">
    <div class="card-section">
        <div class="category align-center flex">
            <span>Nieuwe plenaire vergadering op {{ meeting.date | date }}</span>
        </div>
        <div class="padded-tight flex-col gap-small">
            <!-- QUESTIONS -->
            <div>
                <p class="bold capitalize-first" data-i18n="questions">vragen</p>
                {% if meeting.questions.length > 0 %}
                <ul class="margin:0">
                    {% for question in meeting.questions | limit(3) %}
                    <li>
                        {% if question.topics_summary_nl %}
                        {{ question.topics_summary_nl }}
                        {% else %}
                        {{ question.topics_nl }}
                        {% endif %}
                    </li>
                    {% endfor %}
                </ul>
                {% else %}
                <p style="margin-bottom: 0.5rem;">Geen vragen</p>
                {% endif %}
            </div>

            <!-- PROPOSITIONS -->
            <div>
                <p class="bold capitalize-first" data-i18n="propositions">propositions</p>
                {% if meeting.propositions.length > 0 %}
                <ul class="margin:0">
                    {% for proposition in meeting.propositions | limit(1) %}
                    <li>
                        {{ proposition.title_nl }}
                        {% if proposition.status == "Aangenomen" %}
                        <span class="status small" style="background-color: #28a745; color: white;">aangenomen</span>
                        {% elseif proposition.status == "Verworpen" %}
                        <span class="status small" style="background-color: #dc3545; color: white;">verworpen</span>
                        {% elseif proposition.status == "ZonderVoorwerp" %}
                        <span class="status small" style="background-color: orange; color: white;">zonder voorwerp</span>
                        {% endif %}
                    </li>
                    {% endfor %}
                </ul>
                {% else %}
                <p style="margin-bottom: 0.5rem;">Geen voorstellen</p>
                {% endif %}
            </div>

            <!-- VOTES & ATTENDANCE -->
            <div>
                <p class="bold capitalize-first" data-i18n="votes">votes</p>
                <p style="margin-bottom: 0.5rem;">{{ meeting.votes.length }} stemming(en)</p>
                {% if meeting.allVotes.length > 0 %}
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                    <p class="bold">aanwezigheid</p>
                    <p>{{ attendance.count }}/150 ({{ (attendance.ratio * 100) | round(0, 'floor') }}%)</p>
                </div>
                <div style="border-radius: 5px; background: #e0e0e0; height: 10px; overflow: hidden;">
                    <div style="
                        width: {{ (attendance.ratio * 100) | round(0, 'floor') }}%;
                        height: 100%;
                        background-color: {{ attendanceColor }};
                    "></div>
                </div>
                {% endif %}
            </div>

        </div>
    </div>
    <a href="/sessions/{{ params.sessionId }}/meetings/P{{ meeting.meeting_id }}/"  class="card-section padding flex-row justify-content:space-between align-items:center">
        <p data-i18n="seeMeetingDetails">seeMeetingDetails</p>
        {% lucide "chevron-right" %}
    </a>
</div>
{% endmacro %}
